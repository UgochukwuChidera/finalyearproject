{
  "form_type": "medical_screening_v1",
  "template_path": "templates/medical_screening_blank.tif",
  "fields": [
    {
      "name": "full_name",
      "label_hint": "Full Name",
      "expected_type": "string",
      "critical": true,
      "dictionary": "nigerian_names.csv",
      "validation": {
        "min_length": 2
      },
      "bounding_box": {
        "x": 150,
        "y": 200,
        "w": 300,
        "h": 40
      }
    }
  ],
  "confidence_weights": {
    "w_lp": 0.6,
    "w_dict": 0.4
  },
  "thresholds": {
    "auto_accept": 0.85,
    "review": 0.7
  },
  "preprocessing": {
    "deskew": true,
    "contrast_enhance": true
  },
  "extraction_mode": "ai"
}
